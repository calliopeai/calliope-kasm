{
  "friendly_name": "Calliope AI Chat Studio",
  "description": "AI-powered SQL agent for natural language database queries, streamed to your browser via Kasm Workspaces.",
  "docker_registry": "https://index.docker.io/v1/",
  "image_src": "chat-studio.svg",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "categories": [
    "Development",
    "Database"
  ],
  "architecture": [
    "amd64",
    "arm64"
  ],
  "compatibility": [
    {
      "version": "1.17.x",
      "image": "calliopeai/calliope-chat-studio-kasm:latest",
      "uncompressed_size_mb": 2500
    }
  ]
}
