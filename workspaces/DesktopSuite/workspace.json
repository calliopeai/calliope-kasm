{
  "friendly_name": "Calliope AI Desktop Suite",
  "description": "All Calliope AI desktop apps in one workspace: IDE, Lab, Chat Studio, Loadr, and the CLI.",
  "docker_registry": "https://index.docker.io/v1/",
  "image_src": "desktop-suite.svg",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh'"
    }
  },
  "categories": [
    "Development"
  ],
  "architecture": [
    "amd64",
    "arm64"
  ],
  "compatibility": [
    {
      "version": "1.17.x",
      "image": "calliopeai/calliope-desktop-suite-kasm:latest",
      "uncompressed_size_mb": 6000
    }
  ]
}
