{
  "friendly_name": "Calliope AI CLI Agent",
  "description": "Lightweight Kasm desktop with the Calliope CLI agent pre-installed. AI-powered terminal environment for development and automation.",
  "docker_registry": "https://index.docker.io/v1/",
  "image_src": "calliope-base.svg",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh'"
    }
  },
  "categories": [
    "Development"
  ],
  "architecture": [
    "amd64",
    "arm64"
  ],
  "compatibility": [
    {
      "version": "1.17.x",
      "image": "calliopeai/calliope-base-kasm:latest",
      "uncompressed_size_mb": 1500
    }
  ]
}
